# DATABASE (Railway PostgreSQL)
# Замените на ваш реальный Railway PostgreSQL URL из dashboard
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@containers-us-west-XXX.railway.app:5432/railway

# Redis (используем httpOnly cookies)
REDIS_URL=redis://localhost:6379/0

# RabbitMQ (для email сервиса)
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Другие настройки
DJANGO_DEBUG=True
SECRET_KEY=django-insecure-local-development-key
